# Copy this file to .env.prod and fill in real values before deploying.
# Run: openssl rand -hex 32   to generate a SECRET_KEY

DATABASE_URL=sqlite+aiosqlite:////data/audioannotator.db
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace_with_strong_password_min_12_chars
SECRET_KEY=replace_with_output_of_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
UPLOAD_DIR=/data/uploads
ENVIRONMENT=production
ALLOWED_ORIGINS=http://your-server-ip:3000
