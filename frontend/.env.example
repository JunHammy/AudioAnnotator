# Copy this file to .env.local and set the correct backend URL.
#
# Local dev (no Docker):  use 127.0.0.1 to avoid Docker Desktop IPv6 conflict on Windows
# Local dev (Docker):     use http://backend:8000 (resolved inside Docker network)
# Production:             leave blank — BACKEND_URL is set in docker-compose.yml

BACKEND_URL=http://127.0.0.1:8000